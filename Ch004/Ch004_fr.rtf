mov\tab al, ss:disp[di]}
\par \pard\plain \s31\dbch\af0\langfe1033\dbch\af6\afs20\qj\widctlpar\ltrpar\cf0\loch\f6\fs21\lang1033\li0\ri0\lin0\rin0\fi142\sb0\sa120{\loch
Vous pouvez remplacer les modes d'adressage [si] ou [di] dans la figure 4.12 par les modes d'adressage [si+disp] et [di+disp].}
\par \pard\plain \s31\dbch\af0\langfe1033\dbch\af6\afs20\qj\widctlpar\ltrpar\cf0\loch\f6\fs21\lang1033\li0\ri0\lin0\rin0\fi142\sb0\sa120{\loch
Notez qu'Intel }{\rtlch \ltrch\lang3084\loch
fait encore r\u233\'e9f\u233\'e9rence \u224\'e0 ces modes d\u8217\'92adressage }{\loch
en termes d'adressages bas\u233\'e9s et index\u233\'e9s. La litt\u233\'e9rature Intel ne fait pas de distinction entre les modes }{\rtlch \ltrch\lang3084\loch
avec ou sans }{\loch
la constante. Si vous regardez }{\rtlch\dbch\af0\langfe1033\dbch\af6\afs20 \ltrch\cf0\fs21\lang3084\loch
juste }{\loch
le fonctionnement du mat\u233\'e9riel, la d\u233\'e9finition est raisonnable. Cependant, d'un point de vue purement }{\rtlch\dbch\af0\langfe1033\dbch\af6\afs20 \ltrch\cf0\fs21\lang3084\loch
de programmation}{\loch
, cette distinction peut \u234\'eatre parfois d\u233\'e9terminante. C'est pourquoi, ce }{\rtlch\dbch\af0\langfe1033\dbch\af6\afs20 \ltrch\cf0\fs21\lang3084\loch
livre}{\loch
 emploie diff\u233\'e9rents termes pour les d\u233\'e9crire. Malheureusement, le monde 80x86 n'est pas bien en accord sur le choix d'une terminologie appropri\u233\'e9e. }
\par \trowd\trql\trleft-108\ltrrow\trpaddft3\trpaddt0\trpaddfl3\trpaddl0\trpaddfb3\trpaddb0\trpaddfr3\trpaddr0\clbrdrt\brdrdb\brdrw60\brdrcf1\clpadft3\clpadt108\clpadfr3\clpadr108\clvertalt\cellx8748\pard\plain \s31\dbch\af0\langfe1033\dbch\af6\afs20\qj\widctlpar\ltrpar\cf0\loch\f6\fs21\lang1033\intbl\sb0\sa120{\rtlch \ltrch\fs23\b\loch

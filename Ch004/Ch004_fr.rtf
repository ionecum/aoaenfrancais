\par \pard\plain \s31\dbch\af0\langfe1033\dbch\af6\afs20\qj\widctlpar\ltrpar\cf0\loch\f6\fs21\lang1033\tx567\li567\ri0\lin567\rin0\fi-425\sb0\sa120{\loch
